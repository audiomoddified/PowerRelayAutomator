<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="306.0" prefWidth="482.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="net.audiomodder.powerrelayautomator.HelloController">
  <padding>
    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
  </padding>
  <Pane prefHeight="45.0" prefWidth="258.0">
    <Label text="Relay"/>
    <Label layoutX="386.0" text="State"/>
    <ComboBox fx:id="relayUsbValue" layoutY="18.0" prefHeight="25.0" prefWidth="271.0"/>
    <Button fx:id="relayInitializeButton" layoutX="280.0" layoutY="18.0" mnemonicParsing="false" prefHeight="25.0"
            prefWidth="87.0" text="Intitialize"/>
    <TextField fx:id="relayStateField" layoutX="374.0" layoutY="18.0" prefHeight="25.0" prefWidth="51.0"/>
  </Pane>
  <Pane prefHeight="45.0" prefWidth="258.0">
    <Label text="Temperature Sensor Receiver"/>
    <Label layoutX="386.0" text="State"/>
    <ComboBox fx:id="receiverUsbValue" layoutY="18.0" prefHeight="25.0" prefWidth="271.0"/>
    <Button fx:id="receiverInitializeButton" layoutX="280.0" layoutY="18.0" mnemonicParsing="false" prefHeight="25.0"
            prefWidth="87.0" text="Intitialize"/>
    <TextField fx:id="receiverStateField" layoutX="374.0" layoutY="18.0" prefHeight="25.0" prefWidth="51.0"/>
  </Pane>
  <Pane layoutX="30.0" layoutY="95.0" prefHeight="45.0" prefWidth="258.0">
    <Label text="Log File Location"/>
    <TextField fx:id="fileLocationString" disable="true" editable="false" layoutY="19.0" prefHeight="25.0"
               prefWidth="219.0"/>
    <Button fx:id="openFileChooserButton" layoutX="228.0" layoutY="19.0" mnemonicParsing="false" prefHeight="25.0"
            prefWidth="108.0" text="Choose Location"/>
    <Button fx:id="initializeLogButton" layoutX="345.0" layoutY="19.0" mnemonicParsing="false" text="Initialize Log"/>
  </Pane>
  <Button fx:id="beginStopButton" prefHeight="78.0" prefWidth="429.0" text="Begin" />
</VBox>
